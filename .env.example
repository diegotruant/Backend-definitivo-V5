# =============================================================================
# Digital Twin API — environment template
# Copy to .env and adjust for local dev or production.
# See docs/DEPLOY_BACKEND.md for deployment notes.
# =============================================================================

# --- Runtime (uvicorn) ---
# Dev: bind localhost + reload. Production/Docker: 0.0.0.0, reload off, workers >= 2.
UVICORN_HOST=127.0.0.1
UVICORN_PORT=8000
UVICORN_RELOAD=true
# Process count (uvicorn --workers N). Dev `make run` uses a single worker; Docker default is 2.
# With N>1, in-app rate limits apply per worker — see rate-limit section below.
UVICORN_WORKERS=1

# --- API metadata (OpenAPI / health) ---
DIGITAL_TWIN_API_TITLE=Digital Twin Fisiologico API
DIGITAL_TWIN_API_VERSION=5.2.2

# --- CORS (required when a browser frontend calls this API) ---
# Comma-separated allowlist, e.g. https://app.example.com,http://localhost:5173
# Empty = CORS closed. Never use * with credentials enabled.
DIGITAL_TWIN_CORS_ORIGINS=

# --- Rate limiting (in-memory, per process) ---
# Each uvicorn worker (and each API replica) maintains its own bucket. Effective
# allowance ≈ max_requests × UVICORN_WORKERS × replica_count. For a single global
# cap, set DIGITAL_TWIN_RATE_LIMIT_ENABLED=false and rate-limit at nginx/Caddy/Cloudflare.
DIGITAL_TWIN_RATE_LIMIT_ENABLED=true
DIGITAL_TWIN_RATE_LIMIT_MAX_REQUESTS=120
DIGITAL_TWIN_RATE_LIMIT_WINDOW_S=60

# --- Tenant header (presence check only — not authentication) ---
DIGITAL_TWIN_REQUIRE_ATHLETE_ID=false

# --- Authentication ---
# Mode: none | api_key | jwt  (api_key also activates when API_KEY_AUTH_ENABLED=true)
DIGITAL_TWIN_AUTH_MODE=none
# Legacy flag; prefer DIGITAL_TWIN_AUTH_MODE=api_key
DIGITAL_TWIN_API_KEY_AUTH_ENABLED=false
# Comma-separated allowed keys (api_key mode). Clients send: Authorization: Bearer <key>
DIGITAL_TWIN_API_KEYS=
# Optional per-key athlete-id prefixes: key:prefix1|prefix2,key2:prefix3
DIGITAL_TWIN_API_KEY_ATHLETE_PREFIXES=

# JWT/OAuth (jwt mode) — HS256 dev secret or OIDC JWKS URL for RS256
DIGITAL_TWIN_JWT_SECRET=
DIGITAL_TWIN_JWT_JWKS_URL=
DIGITAL_TWIN_JWT_AUDIENCE=
DIGITAL_TWIN_JWT_ISSUER=
DIGITAL_TWIN_JWT_ALGORITHMS=HS256

# --- Upload and payload limits (bytes unless noted) ---
MAX_UPLOAD_BYTES=41943040
MAX_UPLOAD_FILES=25
MAX_GPX_BYTES=20971520
MAX_POWER_SAMPLES=200000
MAX_PROJECTION_DAYS=400
MAX_CALENDAR_EVENTS=1000
MAX_JSON_DEPTH=64

# --- Optional tooling (not used by api_app.py) ---
# STRESS_BASE_URL=http://127.0.0.1:8000
