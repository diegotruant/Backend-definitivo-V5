# API runtime configuration
DIGITAL_TWIN_API_TITLE=Digital Twin Fisiologico API
DIGITAL_TWIN_API_VERSION=5.2.1
UVICORN_HOST=127.0.0.1
UVICORN_PORT=8000
UVICORN_RELOAD=true

# --- Security limits (V5.1 hardening; all optional, sane defaults in code) ---
# Comma-separated allowlist of frontend origins for CORS. Empty = CORS closed.
DIGITAL_TWIN_CORS_ORIGINS=
# Optional request throttling (in-memory, per-process).
# WARNING: in multi-worker mode each worker has a separate limiter bucket.
DIGITAL_TWIN_RATE_LIMIT_ENABLED=true
DIGITAL_TWIN_RATE_LIMIT_MAX_REQUESTS=120
DIGITAL_TWIN_RATE_LIMIT_WINDOW_S=60
# Optional tenant header enforcement (presence check only, not authentication).
DIGITAL_TWIN_REQUIRE_ATHLETE_ID=false
# Optional API-key auth for athlete-scoped endpoints (legacy; prefer DIGITAL_TWIN_AUTH_MODE).
# When enabled, clients must send: Authorization: Bearer <key>
DIGITAL_TWIN_API_KEY_AUTH_ENABLED=false
# Auth mode: none | api_key | jwt  (api_key also activates when API_KEY_AUTH_ENABLED=true)
DIGITAL_TWIN_AUTH_MODE=none
# Comma-separated allowed keys (api_key mode).
DIGITAL_TWIN_API_KEYS=
# Optional per-key athlete-id prefixes:
# format key:prefix1|prefix2,key2:prefix3
DIGITAL_TWIN_API_KEY_ATHLETE_PREFIXES=
# JWT/OAuth (jwt mode) — HS256 dev secret or OIDC JWKS URL for RS256.
DIGITAL_TWIN_JWT_SECRET=
DIGITAL_TWIN_JWT_JWKS_URL=
DIGITAL_TWIN_JWT_AUDIENCE=
DIGITAL_TWIN_JWT_ISSUER=
DIGITAL_TWIN_JWT_ALGORITHMS=HS256
# Per-file upload cap in bytes (default 40 MB).
MAX_UPLOAD_BYTES=41943040
# Max files per multi-file request (default 25).
MAX_UPLOAD_FILES=25
# Max GPX course size in bytes before XML parsing (default 20 MB).
MAX_GPX_BYTES=20971520
# Max inline power_json samples (default 200000).
MAX_POWER_SAMPLES=200000
# Season projection upper bounds.
MAX_PROJECTION_DAYS=400
MAX_CALENDAR_EVENTS=1000
# Max JSON nesting depth for twin_state / calendar payloads.
MAX_JSON_DEPTH=64
